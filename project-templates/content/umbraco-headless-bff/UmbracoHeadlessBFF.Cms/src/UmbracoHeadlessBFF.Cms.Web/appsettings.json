{
  "$schema": "appsettings-schema.json",
  "ConnectionStrings": {
    "Cache": "FROM_SECRETS",
    "umbracoDbDSN": "FROM_SECRETS",
    "umbracoDbDSN_ProviderName": "System.Data.SqlClient"
  },
  "Caching": {
    "Enabled": true
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Async",
      "Serilog.Sinks.OpenTelemetry",
      "Serilog.Enrichers.ClientInfo",
      "Serilog.Enrichers.Process",
      "Serilog.Exceptions"
    ],
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore.Hosting": "Warning",
        "Microsoft.AspNetCore.Mvc": "Warning",
        "Microsoft.AspNetCore.Routing": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "ZiggyCreatures.Caching.Fusion.FusionCache": "Error",
        "System": "Warning"
      }
    },
    "Enrich": [
      "WithProcessId",
      "WithThreadId",
      "WithClientIp",
      "FromLogContext",
      "WithExceptionDetails",
      {
        "Name": "WithCorrelationId",
        "Args": {
          "addValueIfHeaderAbsence": true
        }
      },
      {
        "Name": "WithRequestHeader",
        "Args": {
          "headerName": "x-site-host",
          "propertyName": "siteHost"
        }
      },
      {
        "Name": "WithRequestHeader",
        "Args": {
          "headerName": "x-site-path",
          "propertyName": "sitePath"
        }
      }
    ],
    "WriteTo": {
      "Async": {
        "Name": "Async",
        "Args": {
          "configure": {
            "Console": "Console",
            "Otel": {
              "Name": "OpenTelemetry",
              "Args": {
                "OnBeginSuppressInstrumentation": "OpenTelemetry.SuppressInstrumentationScope::Begin, OpenTelemetry"
              }
            }
          }
        }
      }
    }
  },
  "Umbraco": {
    "CMS": {
      "Content": {
        "AllowEditInvariantFromNonDefault": true,
        "ContentVersionCleanupPolicy": {
          "EnableCleanup": true
        }
      },
      "DeliveryApi": {
        "ApiKey": "FROM_SECRETS",
        "Enabled": true,
        "PublicAccess": false,
        "RichTextOutputAsJson": false,
        "Media": {
          "Enabled": true,
          "PublicAccess": false
        },
        "OutputCache": {
          "Enabled": true,
          "ContentDuration": "01:00:00",
          "MediaDuration": "01:00:00"
        }
      },
      "Global": {
        //#if (false)
        "Id": "eb281fdb-b0b5-41ab-a107-dd0a655c514f",
        //#endif
        "TimeOut": "01:00:00",
        "Smtp": {
          "Host": "FROM_ENV_CONFIG",
          "Port": "FROM_ENV_CONFIG",
          "Username": "FROM_SECRETS",
          "Password": "FROM_SECRETS"
        },
        "UseHttps": false
      },
      "Runtime": {
        "Mode": "Production"
      },
      "Hosting": {
        "Debug": false
      },
      "ModelsBuilder": {
        "ModelsMode": "Nothing"
      },
      "Security": {
        "AllowConcurrentLogins": false
      },
      "Unattended": {
        "UpgradeUnattended": true
      },
      "WebRouting": {
        "DisableRedirectUrlTracking": true,
        "UmbracoApplicationUrl": "FROM_ENV_CONFIG"
      },
      //#if (false)
      "Imaging": {
        "HMACSecretKey": "yGgS0Ox7EiamMhGXdirYPPlbHpfW8G6Iybg8eEZSyGFUEURnkXLrhRQAhAZd1Fqz4oBjDvplcq/x0Id1BZHhyQ=="
      }
      //#endif
    },
    "Storage": {
      "AzureBlob": {
        "Media": {
          "ConnectionString": "FROM_SECRETS",
          "ContainerName": "FROM_ENV_CONFIG"
        },
        "TemporaryFile": {
          "ConnectionString": "FROM_SECRETS",
          "ContainerName": "FROM_ENV_CONFIG"
        }
      },
      "Cdn": {
        "Url": "FROM_ENV_CONFIG",
        "RemoveMediaFromPath": false
      }
    }
  },
  "uSync": {
    "Settings": {
      "ExportOnSave": "None",
      "ImportOnFirstBoot": true,
      "UIEnabledGroups": "Settings"
    },
    "Sets": {
      "Default": {
        "DisabledHandlers": [
          "LanguageHandler"
        ]
      }
    }
  },
  "PreviewMode": {
    "SecretKey": "FROM_SECRETS"
  },
  "DeliveryApiExtensions": {
    "Preview": {
      "AllowedUserGroupAliases": [
        "admin"
      ]
    },
    "TypedSwagger": {
      "Enabled": true
    }
  }
}
